// ─── DBM Construction Portal — Prisma Schema ──────────────
// Phase 1: Foundation + AI Scope Architect
// Database: PostgreSQL 16

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ─────────────────────────────────────────────────

enum UserRole {
  OWNER
  PROVIDER
  ADMIN
}

enum ProviderType {
  PROFESSIONAL
  SUPPLIER
  FREIGHT
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  NONE
  NOT_APPLICABLE
}

enum ProjectType {
  RESIDENTIAL
  COMMERCIAL
  NEW_BUILD
}

enum ProjectStatus {
  DISCOVERY
  BIDDING
  CONTRACTING
  EXECUTION
  CLOSING
  ARCHIVED
}

enum ScopeStatus {
  DRAFT
  IN_PROGRESS
  COMPLETE
  FINALIZED
}

enum ScopeCreationMode {
  AI_ASSISTED
  MANUAL_UPLOAD
}

enum DocumentCategory {
  LEGAL
  FINANCIAL
  TECHNICAL
  COMPLIANCE
}

enum TradeGroup {
  PLANNING_DESIGN
  CONTRACTORS
  SUPPLIERS
  SERVICES
}

// Phase 5 stub enums
enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum ChangeOrderStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum RfiStatus {
  OPEN
  RESPONDED
  CLOSED
}

enum SubmittalStatus {
  PENDING
  APPROVED
  REJECTED
  RESUBMIT
}

enum DeliveryStatus {
  SCHEDULED
  IN_TRANSIT
  DELIVERED
  DELAYED
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

// ─── CORE MODELS ───────────────────────────────────────────

model User {
  id                 String       @id @default(uuid()) @db.Uuid
  email              String       @unique
  firebaseUid        String       @unique @map("firebase_uid")
  role               UserRole?
  providerType       ProviderType? @map("provider_type")
  name               String?
  phone              String?
  languagePreference String       @default("en") @map("language_preference")
  verificationStatus Boolean      @default(true) @map("verification_status")
  onboardingComplete Boolean      @default(false) @map("onboarding_complete")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  // Relations
  professionalProfile ProfessionalProfile?
  supplierProfile     SupplierProfile?
  freightProfile      FreightProfile?
  projects            Project[]
  uploadedDocuments   ProjectDocument[]
  chatConversations   ChatConversation[]

  @@map("users")
}

// ─── PROVIDER PROFILES ─────────────────────────────────────

model ProfessionalProfile {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @unique @map("user_id") @db.Uuid
  firstName        String        @map("first_name")
  middleName       String?       @map("middle_name")
  lastName         String        @map("last_name")
  companyName      String        @map("company_name")
  contactNumber1   String        @map("contact_number_1")
  contactNumber2   String?       @map("contact_number_2")
  email            String
  website          String?
  address          Json?         // Structured: { street, streetNumber, suite, city, state, country, zipCode }
  yearsInProfession Int?         @map("years_in_profession")
  yearsInBusiness  Int?          @map("years_in_business")
  licenseNumber    String?       @map("license_number")
  licenseStatus    LicenseStatus @default(NOT_APPLICABLE) @map("license_status")
  styleOfWork      String[]      @map("style_of_work")
  awards           String[]      @default([])
  portfolioKey     String?       @map("portfolio_key") // S3 key
  profileImageKey  String?       @map("profile_image_key")
  insuranceCertKey String?       @map("insurance_cert_key")

  // Trade taxonomy
  tradeCategoryId  String?       @map("trade_category_id") @db.Uuid
  tradeNameId      String?       @map("trade_name_id") @db.Uuid

  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  // Relations
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeCategory    TradeCategory? @relation(fields: [tradeCategoryId], references: [id])
  tradeName        TradeName?    @relation(fields: [tradeNameId], references: [id])

  @@index([tradeCategoryId])
  @@index([tradeNameId])
  @@index([licenseStatus])
  @@map("professional_profiles")
}

model SupplierProfile {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @unique @map("user_id") @db.Uuid
  firstName        String        @map("first_name")
  middleName       String?       @map("middle_name")
  lastName         String        @map("last_name")
  companyName      String        @map("company_name")
  contactNumber1   String        @map("contact_number_1")
  contactNumber2   String?       @map("contact_number_2")
  email            String
  website          String?
  address          Json?
  materialTypes    String[]      @map("material_types")
  servicesProvided String[]      @map("services_provided")
  multipleLocations Boolean      @default(false) @map("multiple_locations")
  secondaryAddresses Json?       @map("secondary_addresses") // Array of Address objects
  licenseStatus    LicenseStatus @default(NOT_APPLICABLE) @map("license_status")
  profileImageKey  String?       @map("profile_image_key")
  portfolioKey     String?       @map("portfolio_key")

  tradeCategoryId  String?       @map("trade_category_id") @db.Uuid
  tradeNameId      String?       @map("trade_name_id") @db.Uuid

  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeCategory    TradeCategory? @relation(fields: [tradeCategoryId], references: [id])
  tradeName        TradeName?    @relation(fields: [tradeNameId], references: [id])

  @@map("supplier_profiles")
}

model FreightProfile {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @unique @map("user_id") @db.Uuid
  firstName        String        @map("first_name")
  middleName       String?       @map("middle_name")
  lastName         String        @map("last_name")
  companyName      String        @map("company_name")
  contactNumber1   String        @map("contact_number_1")
  contactNumber2   String?       @map("contact_number_2")
  email            String
  website          String?
  address          Json?
  serviceTypes     String[]      @map("service_types")
  servicesProvided String[]      @map("services_provided")
  multipleLocations Boolean      @default(false) @map("multiple_locations")
  secondaryAddresses Json?       @map("secondary_addresses")
  licenseStatus    LicenseStatus @default(NOT_APPLICABLE) @map("license_status")
  profileImageKey  String?       @map("profile_image_key")
  portfolioKey     String?       @map("portfolio_key")

  tradeCategoryId  String?       @map("trade_category_id") @db.Uuid
  tradeNameId      String?       @map("trade_name_id") @db.Uuid

  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeCategory    TradeCategory? @relation(fields: [tradeCategoryId], references: [id])
  tradeName        TradeName?    @relation(fields: [tradeNameId], references: [id])

  @@map("freight_profiles")
}

// ─── TRADE TAXONOMY ────────────────────────────────────────

model TradeCategory {
  id    String     @id @default(uuid()) @db.Uuid
  name  TradeGroup @unique
  label String     // Human-readable: "Planning & Design"

  trades               TradeName[]
  professionalProfiles ProfessionalProfile[]
  supplierProfiles     SupplierProfile[]
  freightProfiles      FreightProfile[]

  @@map("trade_categories")
}

model TradeName {
  id         String  @id @default(uuid()) @db.Uuid
  categoryId String  @map("category_id") @db.Uuid
  name       String  // "General Contractor"
  slug       String  @unique // "general-contractor"

  category             TradeCategory         @relation(fields: [categoryId], references: [id])
  professionalProfiles ProfessionalProfile[]
  supplierProfiles     SupplierProfile[]
  freightProfiles      FreightProfile[]

  @@index([categoryId])
  @@map("trade_names")
}

// ─── PROJECTS ──────────────────────────────────────────────

model Project {
  id                String            @id @default(uuid()) @db.Uuid
  ownerId           String            @map("owner_id") @db.Uuid
  title             String
  type              ProjectType       @default(RESIDENTIAL)
  status            ProjectStatus     @default(DISCOVERY)
  zipCode           String            @map("zip_code")
  description       String?
  scopeCreationMode ScopeCreationMode @default(AI_ASSISTED) @map("scope_creation_mode")
  deletedAt         DateTime?         @map("deleted_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  owner             User              @relation(fields: [ownerId], references: [id])
  documents         ProjectDocument[]
  scopeDocument     ScopeDocument?
  // Phase 5+ stubs
  invoices          Invoice[]
  changeOrders      ChangeOrder[]
  rfis              Rfi[]
  submittals        Submittal[]
  deliveryReports   DeliveryReport[]
  progressReports   ProgressReport[]

  @@index([ownerId])
  @@index([zipCode])
  @@index([status])
  @@map("projects")
}

model ProjectDocument {
  id             String           @id @default(uuid()) @db.Uuid
  projectId      String           @map("project_id") @db.Uuid
  category       DocumentCategory @default(TECHNICAL)
  filename       String
  s3Key          String           @map("s3_key")
  uploadedById   String           @map("uploaded_by_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at")

  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy     User             @relation(fields: [uploadedById], references: [id])

  @@index([projectId])
  @@map("project_documents")
}

// ─── AI SCOPE ARCHITECT ────────────────────────────────────

model ScopeDocument {
  id                  String      @id @default(uuid()) @db.Uuid
  projectId           String      @unique @map("project_id") @db.Uuid
  status              ScopeStatus @default(DRAFT)
  completenessPercent Int         @default(0) @map("completeness_percent")
  pdfS3Key            String?     @map("pdf_s3_key")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  // Structured scope data — populated field-by-field by the AI
  projectScope        String?     @map("project_scope")
  dimensions          String?
  materialGrade       String?     @map("material_grade")
  timeline            String?
  milestones          String?
  specialConditions   String?     @map("special_conditions")
  preferredStartDate  String?     @map("preferred_start_date")
  siteConstraints     String?     @map("site_constraints")
  aestheticPreferences String?    @map("aesthetic_preferences")

  project             Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  interviewTurns      ScopeInterviewTurn[]

  @@map("scope_documents")
}

model ScopeInterviewTurn {
  id              String   @id @default(uuid()) @db.Uuid
  scopeDocumentId String   @map("scope_document_id") @db.Uuid
  turnNumber      Int      @map("turn_number")
  questionText    String   @map("question_text")
  answerText      String?  @map("answer_text")
  fieldPopulated  String?  @map("field_populated") // Which ScopeDocument field was updated
  createdAt       DateTime @default(now()) @map("created_at")

  scopeDocument   ScopeDocument @relation(fields: [scopeDocumentId], references: [id], onDelete: Cascade)

  @@index([scopeDocumentId])
  @@map("scope_interview_turns")
}

// ─── AI CHAT (General Assistant) ───────────────────────────

model ChatConversation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String   // USER | ASSISTANT | TOOL
  content        Json     // Supports Anthropic content blocks
  tokensIn       Int?     @map("tokens_in")
  tokensOut      Int?     @map("tokens_out")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("chat_messages")
}

// ─── FEATURE FLAGS (A/B Testing) ───────────────────────────

model FeatureFlag {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique // e.g. "scope_creation_mode"
  variant   String   // e.g. "ai_assisted" | "manual_upload"
  userId    String?  @map("user_id") @db.Uuid // null = global default
  createdAt DateTime @default(now()) @map("created_at")

  @@index([key, userId])
  @@map("feature_flags")
}

// ─── PHASE 5+ STUB MODELS (schema-ready, not built yet) ───

model Invoice {
  id        String        @id @default(uuid()) @db.Uuid
  projectId String        @map("project_id") @db.Uuid
  status    InvoiceStatus @default(DRAFT)
  amount    Decimal?      @db.Decimal(12, 2)
  dueDate   DateTime?     @map("due_date")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  project   Project       @relation(fields: [projectId], references: [id])
  @@map("invoices")
}

model ChangeOrder {
  id          String            @id @default(uuid()) @db.Uuid
  projectId   String            @map("project_id") @db.Uuid
  status      ChangeOrderStatus @default(PENDING)
  description String?
  impactAmount Decimal?         @map("impact_amount") @db.Decimal(12, 2)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  project     Project           @relation(fields: [projectId], references: [id])
  @@map("change_orders")
}

model Rfi {
  id        String    @id @default(uuid()) @db.Uuid
  projectId String    @map("project_id") @db.Uuid
  status    RfiStatus @default(OPEN)
  question  String?
  response  String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  project   Project   @relation(fields: [projectId], references: [id])
  @@map("rfis")
}

model Submittal {
  id        String          @id @default(uuid()) @db.Uuid
  projectId String          @map("project_id") @db.Uuid
  status    SubmittalStatus @default(PENDING)
  title     String?
  s3Key     String?         @map("s3_key")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  project   Project         @relation(fields: [projectId], references: [id])
  @@map("submittals")
}

model DeliveryReport {
  id        String         @id @default(uuid()) @db.Uuid
  projectId String         @map("project_id") @db.Uuid
  status    DeliveryStatus @default(SCHEDULED)
  vendor    String?
  items     Json?
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  project   Project        @relation(fields: [projectId], references: [id])
  @@map("delivery_reports")
}

model ProgressReport {
  id          String       @id @default(uuid()) @db.Uuid
  projectId   String       @map("project_id") @db.Uuid
  status      ReportStatus @default(DRAFT)
  summary     String?
  percentDone Int?         @map("percent_done")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  project     Project      @relation(fields: [projectId], references: [id])
  @@map("progress_reports")
}
